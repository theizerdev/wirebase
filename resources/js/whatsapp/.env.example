# Configuración del Servidor
PORT=3001
NODE_ENV=development
API_VERSION=v2

# Base de Datos
DB_HOST=localhost
DB_PORT=3306
DB_NAME=vargas_centro
DB_USER=root
DB_PASS=

# Redis (para colas)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=tu_jwt_secret_super_seguro_aqui
JWT_EXPIRES_IN=24h

# WhatsApp
WHATSAPP_SESSION_NAME=vargas-centro
WHATSAPP_WEBHOOK_URL=http://localhost:8000/api/whatsapp/webhook
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY=5000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
MESSAGE_RATE_LIMIT=10

# Anti-Block Protection
ANTI_BLOCK_MESSAGE_DELAY_MS=30000
ANTI_BLOCK_MAX_PER_HOUR=10
ANTI_BLOCK_MAX_PER_DAY=50
ANTI_BLOCK_BUSINESS_HOURS_START=7
ANTI_BLOCK_BUSINESS_HOURS_END=22

# Logs
LOG_LEVEL=info
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# Archivos
UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,text/plain

# Seguridad
CORS_ORIGIN=http://localhost:8000
HELMET_ENABLED=true
TRUST_PROXY=false